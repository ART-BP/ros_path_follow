<launch>
  <param name="robot_description" textfile="$(find motion_control)/urdf/urdf/go2w_description.urdf"/>

  <node pkg="joint_state_publisher_gui" type="joint_state_publisher_gui" name="joint_state_publisher"/>
  <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher"/>
  <node pkg="rviz" type="rviz" name="rviz" 
  args="-d $(find motion_control)/rviz/motion_control.rviz"/>
</launch>